{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AndyAI Finance Engine Extraction Record",
  "type": "object",
  "required": [
    "field",
    "value",
    "source_reference",
    "confidence",
    "review_state"
  ],
  "properties": {
    "field": {
      "type": "string"
    },
    "value": {},
    "unit": {
      "type": "string"
    },
    "source_reference": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "review_state": {
      "type": "string",
      "enum": [
        "unreviewed",
        "accepted",
        "challenged",
        "rejected"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}