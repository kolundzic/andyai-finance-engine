{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AndyAI Finance Engine Business Input",
  "type": "object",
  "required": ["project_name", "currency", "revenue_streams", "costs", "assumptions"],
  "properties": {
    "project_name": { "type": "string" },
    "currency": { "type": "string" },
    "revenue_streams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "monthly_amount"],
        "properties": {
          "name": { "type": "string" },
          "monthly_amount": { "type": "number" }
        }
      }
    },
    "costs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "monthly_amount"],
        "properties": {
          "name": { "type": "string" },
          "monthly_amount": { "type": "number" }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
