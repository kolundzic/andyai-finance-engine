{
  "version": "10.1.0",
  "mode": "supabase_lab_read_only_runtime_gate",
  "mutation_allowed": false,
  "production_runtime_allowed": false,
  "billing_allowed": false,
  "checkout_allowed": false,
  "webhooks_allowed": false,
  "paid_runtime_allowed": false,
  "table_allowlist": [
    "fe_approval_decisions",
    "fe_audit_events",
    "fe_export_records",
    "fe_manual_review_queue",
    "fe_membership_states",
    "fe_quota_policies",
    "fe_quota_windows",
    "fe_usage_events",
    "fe_workspace_members",
    "fe_workspaces"
  ],
  "blocked_operations": [
    "insert",
    "update",
    "delete",
    "upsert",
    "truncate",
    "drop",
    "alter",
    "create",
    "grant",
    "revoke",
    "mutation_rpc",
    "billing_activation",
    "checkout_creation",
    "webhook_processing"
  ],
  "secret_boundary": {
    "service_role_in_browser": false,
    "db_url_in_repo": false,
    "database_password_in_repo": false,
    "env_local_tracked": false
  }
}
